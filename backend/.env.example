# =============================================================================
# Boot settings (env-only, server restart required to take effect)
# =============================================================================

# PostgreSQL connection URL. Schemes: postgresql or postgresql+psycopg
DATABASE_URL=postgresql+psycopg://nokodo-ai-admin:nokodo-ai@127.0.0.1:5432/nokodo-ai-dev

# Runtime environment: dev | production
ENV=dev

DEBUG=true
JSON_LOGS=false
TESTING=false

# Set to true if using branching Alembic migrations (uses 'heads' instead of 'head')
BRANCHING_MIGRATIONS=false

# =============================================================================
# Runtime settings (NOKODO__<SECTION>__<FIELD>)
# DB overrides apply only to admin-writable (non-write-locked) fields.
# =============================================================================

# -----------------------------------------------------------------------------
# Cache and tasks (env-only / write-locked - API, worker, and scheduler must agree)
# -----------------------------------------------------------------------------
NOKODO__CACHE__REDIS__URL=redis://127.0.0.1:6380/0
NOKODO__CACHE__REDIS__CLIENT_NAME=nokodo_ai
# NOKODO__TASKS__TASKIQ__QUEUE_NAME=nokodo-ai:taskiq:queue
# NOKODO__TASKS__TASKIQ__RESULT_TTL_SECONDS=86400
# NOKODO__TASKS__TASKIQ__MAX_CONNECTIONS=32
# NOKODO__TASKS__TASKIQ__SCHEDULE_PREFIX=nokodo-ai:taskiq:schedules

# -----------------------------------------------------------------------------
# Security (env-only / write-locked - cannot be updated via API)
# -----------------------------------------------------------------------------

# REQUIRED in production - generate with: openssl rand -hex 32
NOKODO__SECURITY__SECRET_KEY=your-secret-key-here-change-in-production
NOKODO__SECURITY__JWT_ALGORITHM=HS256
NOKODO__SECURITY__ENABLE_OAUTH=true

# Allowed host patterns for Origin/CSRF/WebSocket validation:
#   *            matches everything
#   .local       matches "local" and "*.local"
#   example.com  exact match only
NOKODO__SECURITY__ALLOWED_HOSTS=localhost,127.0.0.1,.local

# CORS - comma-separated or JSON array
NOKODO__SECURITY__CORS_ORIGINS=http://localhost:888,http://localhost:8383
# CORS regex patterns - must be a JSON array string
NOKODO__SECURITY__CORS_ORIGINS_REGEX=["^https?://.*\.local:888$","^https?://.*\.local:8383$"]

# -----------------------------------------------------------------------------
# Security (API/DB writable)
# -----------------------------------------------------------------------------
NOKODO__SECURITY__ALLOW_SIGNUPS=true
NOKODO__SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
NOKODO__SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=90
# Set to false for HTTP-only local dev
NOKODO__SECURITY__AUTH_COOKIE_SECURE=false
NOKODO__SECURITY__REQUIRE_EMAIL_VERIFICATION=true
# Comma-separated list of allowed email domains (empty = allow all)
# NOKODO__SECURITY__ALLOWED_EMAIL_DOMAINS=example.com,example.org

# -----------------------------------------------------------------------------
# OIDC (optional) - all fields required when OIDC__ENABLED=true
# -----------------------------------------------------------------------------
# NOKODO__SECURITY__OIDC__ENABLED=false
# NOKODO__SECURITY__OIDC__ISSUER_URL=https://accounts.google.com
# NOKODO__SECURITY__OIDC__CLIENT_ID=your-client-id
# NOKODO__SECURITY__OIDC__CLIENT_SECRET=your-client-secret
# NOKODO__SECURITY__OIDC__REDIRECT_URI=http://localhost:888/auth/oidc/callback
# NOKODO__SECURITY__OIDC__SCOPES=["openid","profile","email"]
# NOKODO__SECURITY__OIDC__ONLY=false

# -----------------------------------------------------------------------------
# Branding
# -----------------------------------------------------------------------------
# NOKODO__BRANDING__SITE_NAME=nokodo
# NOKODO__BRANDING__PRIMARY_COLOR=#6366f1
# NOKODO__BRANDING__SUPPORT_EMAIL=support@example.com
# NOKODO__BRANDING__ADMIN_EMAIL=admin@example.com
# Public origins used for link generation and CORS:
NOKODO__BRANDING__PUBLIC_FRONTEND_ORIGIN=http://localhost:888
NOKODO__BRANDING__PUBLIC_CDN_ORIGIN=
# NOKODO__BRANDING__PUBLIC_CONSOLE_ORIGIN=http://localhost:8383
# NOKODO__BRANDING__ANALYTICS_KEY=

# -----------------------------------------------------------------------------
# Limits
# -----------------------------------------------------------------------------
# NOKODO__LIMITS__MAX_THREADS_PER_USER=100
# NOKODO__LIMITS__MAX_MESSAGES_PER_THREAD=1000
# NOKODO__LIMITS__MAX_FILE_SIZE_MB=50
# NOKODO__LIMITS__RATE_LIMIT_REQUESTS_PER_MINUTE=1500

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Backend: local | s3
NOKODO__ASSETS__STORAGE__BACKEND=local
# NOKODO__ASSETS__STORAGE__LOCAL__ROOT_PATH=data/uploads

# S3-compatible storage (uncomment and configure when BACKEND=s3)
# NOKODO__ASSETS__STORAGE__S3__ENDPOINT_URL=http://localhost:9000
# NOKODO__ASSETS__STORAGE__S3__BUCKET=nokodo-ai
# NOKODO__ASSETS__STORAGE__S3__REGION=us-east-1
# NOKODO__ASSETS__STORAGE__S3__ACCESS_KEY_ID=minioadmin
# NOKODO__ASSETS__STORAGE__S3__SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# Vector database (Qdrant by default)
# -----------------------------------------------------------------------------
# NOKODO__ASSETS__VECTOR_DATABASE__PROVIDER=qdrant
# NOKODO__ASSETS__VECTOR_DATABASE__QDRANT__URL=qdrant:6334
# NOKODO__ASSETS__VECTOR_DATABASE__QDRANT__USE_GRPC=true
# NOKODO__ASSETS__VECTOR_DATABASE__QDRANT__API_KEY=

# Other providers:
# NOKODO__ASSETS__VECTOR_DATABASE__CHROMA__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__CHROMA__API_KEY=
# NOKODO__ASSETS__VECTOR_DATABASE__PINECONE__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__PINECONE__API_KEY=
# NOKODO__ASSETS__VECTOR_DATABASE__WEAVIATE__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__WEAVIATE__API_KEY=
# NOKODO__ASSETS__VECTOR_DATABASE__MILVUS__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__MILVUS__TOKEN=
# NOKODO__ASSETS__VECTOR_DATABASE__PGVECTOR__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__REDIS__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__REDIS__PASSWORD=
# NOKODO__ASSETS__VECTOR_DATABASE__OPENSEARCH__URL=
# NOKODO__ASSETS__VECTOR_DATABASE__OPENSEARCH__API_KEY=

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
# Default agent IDs tried in order (JSON array)
# NOKODO__AI__DEFAULT_AGENT_IDS=["agent-id-1"]

# Background task model overrides
# NOKODO__AI__TASKS__DEFAULT_MODEL_ID=
# NOKODO__AI__TASKS__THREAD_METADATA_MODEL_ID=
# NOKODO__AI__TASKS__THREAD_MAINTENANCE_MODEL_ID=
# NOKODO__AI__TASKS__INPUT_AUTOCOMPLETE_MODEL_ID=

# Message windowing (disabled by default)
# NOKODO__AI__WINDOWING__ENABLED=false
# NOKODO__AI__WINDOWING__MAX_MESSAGES=50

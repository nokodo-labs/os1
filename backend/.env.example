# Boot settings (env-only, reboot required)
DATABASE_URL=postgresql+psycopg://nokodo-ai-admin:nokodo-ai@127.0.0.1:5432/nokodo-ai-dev
ENV=dev
DEBUG=true
JSON_LOGS=false
TESTING=false

# Runtime settings (NOKODO__<SECTION>__<FIELD>)
# NOTE: DB overrides apply only to admin-writable fields.

# Security (env-only)
NOKODO__SECURITY__SECRET_KEY=your-secret-key-here-change-in-production
NOKODO__SECURITY__JWT_ALGORITHM=HS256
# Django-style allowed host patterns used for Origin validation (CSRF + WebSocket):
# - *            matches everything
# - .local       matches "local" and "*.local"
# - example.com  exact match only
NOKODO__SECURITY__ALLOWED_HOSTS=localhost,127.0.0.1,.local
NOKODO__SECURITY__CORS_ORIGINS=http://localhost:888,http://localhost:8383
NOKODO__SECURITY__CORS_ORIGINS_REGEX=["^https?://.*\\.local:888$","^https?://.*\\.local:8383$"]

# Security (API/DB writable)
NOKODO__SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
NOKODO__SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=90
NOKODO__SECURITY__AUTH_COOKIE_SECURE=false

# Branding / public origins (safe to expose to clients)
NOKODO__BRANDING__PUBLIC_FRONTEND_ORIGIN=http://localhost:888
NOKODO__BRANDING__PUBLIC_CDN_ORIGIN=

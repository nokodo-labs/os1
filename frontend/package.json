{
	"name": "frontend",
	"private": true,
	"version": "0.3.0-rc.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"generate:api-types": "uv run --project ../backend python ../tools/export-openapi.py .openapi-schema.json && openapi-typescript .openapi-schema.json -o src/lib/api/types.ts && node -e \"var f='src/lib/api/types.ts',s=require('fs');s.writeFileSync(f,'// @ts-nocheck\\n'+s.readFileSync(f,'utf8'));try{s.unlinkSync('.openapi-schema.json')}catch(e){}\""
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"@types/three": "^0.184.0",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"happy-dom": "^20.9.0",
		"openapi-typescript": "^7.13.0",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@dayflow/core": "^3.6.0",
		"@dayflow/plugin-drag": "^1.5.0",
		"@dayflow/svelte": "^3.6.0",
		"@floating-ui/dom": "^1.7.6",
		"@internationalized/date": "^3.12.1",
		"@tiptap/core": "^3.22.5",
		"@tiptap/extension-placeholder": "^3.22.5",
		"@tiptap/extension-typography": "^3.22.5",
		"@tiptap/extension-underline": "^3.22.5",
		"@tiptap/pm": "^3.22.5",
		"@tiptap/starter-kit": "^3.22.5",
		"@types/turndown": "^5.0.5",
		"clsx": "^2.1.1",
		"marked": "^18.0.3",
		"mermaid": "^11.14.0",
		"ogl": "^1.0.11",
		"openapi-fetch": "^0.17.0",
		"prosemirror-keymap": "^1.2.3",
		"svelte-streamdown": "^3.0.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"three": "^0.184.0",
		"tippy.js": "^6.3.7",
		"tslib": "^2.8.1",
		"turndown": "^7.2.4",
		"tw-animate-css": "^1.4.0",
		"y-prosemirror": "^1.3.7",
		"yjs": "^13.6.30"
	}
}

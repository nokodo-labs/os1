{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "backend: FastAPI Uvicorn server",
			"type": "debugpy",
			"request": "launch",
			"module": "uvicorn",
			"preLaunchTask": "backend: ensure dev deps",
			"args": [
				"api.main:app",
				"--host",
				"0.0.0.0",
				"--port",
				"1383",
				"--loop",
				"api.runtime:selector_loop_factory"
			],
			"jinja": true,
			"justMyCode": true,
			"cwd": "${workspaceFolder}/backend",
			"env": {
				"PYTHONPATH": "${workspaceFolder}/backend"
			},
			"console": "integratedTerminal",
			"purpose": ["debug-in-terminal"]
		},
		{
			"name": "TaskIQ: worker",
			"type": "debugpy",
			"request": "launch",
			"module": "api.taskiq",
			"preLaunchTask": "Docker: ensure dev deps",
			"args": [
				"worker",
				"api.taskiq:broker",
				"api.tasks.registry",
				"--workers",
				"auto",
				"--max-async-tasks",
				"25"
			],
			"justMyCode": true,
			"subProcess": true,
			"cwd": "${workspaceFolder}/backend",
			"env": {
				"PYTHONPATH": "${workspaceFolder}/backend"
			},
			"console": "integratedTerminal"
		},
		{
			"name": "TaskIQ: scheduler",
			"type": "debugpy",
			"request": "launch",
			"module": "api.taskiq",
			"preLaunchTask": "Docker: ensure dev deps",
			"args": ["scheduler", "api.taskiq:scheduler", "api.tasks.registry"],
			"justMyCode": true,
			"subProcess": true,
			"cwd": "${workspaceFolder}/backend",
			"env": {
				"PYTHONPATH": "${workspaceFolder}/backend"
			},
			"console": "integratedTerminal"
		},
		{
			"name": "Python: current file",
			"type": "debugpy",
			"request": "launch",
			"program": "${file}",
			"console": "integratedTerminal",
			"cwd": "${workspaceFolder}/backend",
			"env": {
				"PYTHONPATH": "${workspaceFolder}/backend"
			}
		},
		{
			"name": "backend: Pytest",
			"type": "debugpy",
			"request": "launch",
			"module": "pytest",
			"args": ["-v", "${file}"],
			"console": "integratedTerminal",
			"cwd": "${workspaceFolder}/backend",
			"env": {
				"PYTHONPATH": "${workspaceFolder}/backend"
			}
		},
		{
			"name": "frontend: Vite dev server",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": ["run", "dev"],
			"cwd": "${workspaceFolder}/frontend",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"name": "frontend: Chrome",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:888",
			"webRoot": "${workspaceFolder}/frontend/src",
			"sourceMapPathOverrides": {
				"webpack:///src/*": "${webRoot}/*"
			}
		},
		{
			"name": "console: Vite dev server",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "npm",
			"runtimeArgs": [
				"run",
				"dev",
				"--",
				"--host",
				"0.0.0.0",
				"--port",
				"8383"
			],
			"cwd": "${workspaceFolder}/console",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"name": "console: Chrome",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:8383",
			"webRoot": "${workspaceFolder}/console/src",
			"sourceMapPathOverrides": {
				"webpack:///src/*": "${webRoot}/*"
			}
		},
		{
			"name": "Docker: attach backend API",
			"type": "debugpy",
			"request": "attach",
			"connect": {
				"host": "localhost",
				"port": 5678
			},
			"justMyCode": true,
			"pathMappings": [
				{
					"localRoot": "${workspaceFolder}/backend",
					"remoteRoot": "/app"
				}
			]
		},
		{
			"name": "Docker: attach TaskIQ worker",
			"type": "debugpy",
			"request": "attach",
			"connect": {
				"host": "localhost",
				"port": 5679
			},
			"justMyCode": true,
			"subProcess": true,
			"pathMappings": [
				{
					"localRoot": "${workspaceFolder}/backend",
					"remoteRoot": "/app"
				}
			]
		},
		{
			"name": "Docker: attach TaskIQ scheduler",
			"type": "debugpy",
			"request": "attach",
			"connect": {
				"host": "localhost",
				"port": 5680
			},
			"justMyCode": true,
			"subProcess": true,
			"pathMappings": [
				{
					"localRoot": "${workspaceFolder}/backend",
					"remoteRoot": "/app"
				}
			]
		}
	],
	"compounds": [
		{
			"name": "Docker: API + TaskIQ debug stack",
			"configurations": [
				"Docker: attach backend API",
				"Docker: attach TaskIQ worker",
				"Docker: attach TaskIQ scheduler"
			],
			"preLaunchTask": "Docker: debug API + TaskIQ",
			"postDebugTask": "Docker: stop debug API + TaskIQ",
			"stopAll": true,
			"presentation": {
				"hidden": false,
				"group": "docker",
				"order": 1
			}
		},
		{
			"name": "backend: API + TaskIQ",
			"configurations": ["backend: FastAPI Uvicorn server"],
			"stopAll": true,
			"presentation": {
				"hidden": false,
				"group": "backend",
				"order": 1
			}
		},
		{
			"name": "full stack",
			"configurations": [
				"backend: FastAPI Uvicorn server",
				"frontend: Vite dev server",
				"console: Vite dev server"
			],
			"stopAll": true,
			"presentation": {
				"hidden": false,
				"group": "fullstack",
				"order": 1
			}
		},
		{
			"name": "API + frontend",
			"configurations": [
				"backend: FastAPI Uvicorn server",
				"frontend: Vite dev server"
			],
			"stopAll": true,
			"presentation": {
				"hidden": false,
				"group": "fullstack",
				"order": 2
			}
		},
		{
			"name": "API + console",
			"configurations": [
				"backend: FastAPI Uvicorn server",
				"console: Vite dev server"
			],
			"stopAll": true,
			"presentation": {
				"hidden": false,
				"group": "fullstack",
				"order": 2
			}
		}
	]
}

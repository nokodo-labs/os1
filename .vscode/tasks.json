		{
			"label": "Docker: down",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml down",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Docker: dev mode",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile local up -d --build",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		}
	]
}

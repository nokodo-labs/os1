{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Backend: Install Dependencies",
			"type": "shell",
			"command": "pip install -e .[api,dev]",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Backend: Run Server",
			"type": "shell",
			"command": "uvicorn api.main:app --reload --host 0.0.0.0 --port 8000",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Application startup complete"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Backend: Run Tests",
			"type": "shell",
			"command": "pytest -v",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Frontend: Install Dependencies",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Frontend: Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Frontend: Build",
			"type": "shell",
			"command": "npm run build",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Frontend: Check",
			"type": "shell",
			"command": "npm run check",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Frontend: Test",
			"type": "shell",
			"command": "npm run test",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Frontend: Generate API Types",
			"type": "shell",
			"command": "npm run generate:api-types",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Console: Install Dependencies",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Console: Dev Server",
			"type": "shell",
			"command": "npm run dev -- --host --port 8383",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Console: Build",
			"type": "shell",
			"command": "npm run build",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Console: Check",
			"type": "shell",
			"command": "npm run check",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Console: Generate API Types",
			"type": "shell",
			"command": "npm run generate:api-types",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Docker: Dev Dependencies",
			"type": "shell",
			"command": "docker compose --profile deps up -d",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "never",
				"panel": "dedicated"
			}
		},
		{
			"label": "Docker: Build All",
			"type": "shell",
			"command": "docker compose build",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Docker: Up",
			"type": "shell",
			"command": "docker compose --profile local up -d",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Docker: Down",
			"type": "shell",
			"command": "docker compose down",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Docker: Dev Mode",
			"type": "shell",
			"command": "docker compose --profile local up -d --build",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		}
	]
}

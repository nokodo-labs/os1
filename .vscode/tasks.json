{
	"version": "2.0.0",
	"tasks": [
		// ═══════════════════════════════════════
		// BACKEND
		// ═══════════════════════════════════════
		{
			"label": "Backend: Install Dependencies",
			"type": "shell",
			"command": "uv sync --all-extras",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Backend: Run Server",
			"type": "shell",
			"command": "uv run uvicorn api.main:app --host 0.0.0.0 --port 8000 --loop api.core.runtime:selector_loop_factory",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"dependsOn": "Docker: Ensure Dev Deps",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Application startup complete"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Backend: Run Tests",
			"type": "shell",
			"command": "uv run pytest -q --tb=short --cov-report=term-missing:skip-covered",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"dependsOn": "Docker: Ensure Dev Deps",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "new", // temporarily set to new for AI compat.
				"showReuseMessage": false
			},
			"problemMatcher": []
		},
		{
			"label": "Backend: Check API Alive",
			"type": "process",
			"command": "node",
			"args": [
				"-e",
				"const url=process.env.API_HEALTH_URL||'http://localhost:8000/health';const timeoutMs=Number(process.env.API_HEALTH_TIMEOUT_MS||60000);const intervalMs=Number(process.env.API_HEALTH_INTERVAL_MS||1000);const start=Date.now();const urlObj=new URL(url);const http=require(urlObj.protocol==='https:'?'https':'http');async function isOk(){return await new Promise(resolve=>{const req=http.request(urlObj,{method:'GET',headers:{accept:'application/json'}},res=>{res.resume();resolve(Boolean(res.statusCode&&res.statusCode>=200&&res.statusCode<300));});req.on('error',()=>resolve(false));req.end();});}(async()=>{for(;;){if(await isOk()){console.log('API alive: '+url);process.exit(0);}if(Date.now()-start>timeoutMs){console.error('API not reachable after '+timeoutMs+'ms: '+url);process.exit(1);}await new Promise(r=>setTimeout(r,intervalMs));}})();"
			],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},

		// ═══════════════════════════════════════
		// FRONTEND
		// ═══════════════════════════════════════
		{
			"label": "Frontend: Install Dependencies",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Frontend: Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Frontend: Build",
			"type": "shell",
			"command": "npm run build",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Frontend: Lint",
			"type": "shell",
			"command": "npm run lint",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Frontend: Format",
			"type": "shell",
			"command": "npm run format",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Frontend: Check",
			"type": "shell",
			"command": "npm run check",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "Frontend: Test",
			"type": "shell",
			"command": "npm run test",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "Frontend: Test Coverage",
			"type": "shell",
			"command": "npm run test:coverage",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "Frontend: Generate API Types",
			"type": "shell",
			"command": "npm run generate:api-types",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"dependsOn": "Backend: Check API Alive",
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},

		// ═══════════════════════════════════════
		// CONSOLE
		// ═══════════════════════════════════════
		{
			"label": "Console: Install Dependencies",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Console: Dev Server",
			"type": "shell",
			"command": "npm run dev -- --host --port 8383",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Console: Build",
			"type": "shell",
			"command": "npm run build",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Console: Format",
			"type": "shell",
			"command": "npm run format",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Console: Check",
			"type": "shell",
			"command": "npm run check",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "Console: Generate API",
			"type": "shell",
			"command": "npm run generate:api",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"dependsOn": "Backend: Check API Alive",
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},

		// ═══════════════════════════════════════
		// DOCKER
		// ═══════════════════════════════════════
		{
			"label": "Docker: Ensure Dev Deps",
			"type": "shell",
			"command": "docker compose --profile deps up -d",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"showReuseMessage": false,
				"close": true
			}
		},
		{
			"label": "Docker: Build All",
			"type": "shell",
			"command": "docker compose build",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Docker: Up",
			"type": "shell",
			"command": "docker compose --profile local up -d",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Docker: Down",
			"type": "shell",
			"command": "docker compose down",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Docker: Dev Mode",
			"type": "shell",
			"command": "docker compose --profile local up -d --build",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		}
	]
}

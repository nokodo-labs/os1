{
	"version": "2.0.0",
	"tasks": [
		// backend
		{
			"label": "backend: install dependencies",
			"type": "shell",
			"command": "uv sync --all-extras",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "backend: format",
			"type": "shell",
			"command": "uv run ruff format .",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "backend: run server",
			"type": "shell",
			"command": "uv run uvicorn api.main:app --host 0.0.0.0 --port 1383 --loop api.runtime:selector_loop_factory",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"dependsOn": "backend: ensure dev deps",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Application startup complete"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "backend: ensure dev deps",
			"type": "shell",
			"command": "echo backend dev deps ready",
			"dependsOn": ["Docker: ensure dev deps", "Docker: TaskIQ up"],
			"dependsOrder": "sequence",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"showReuseMessage": false,
				"close": true
			}
		},
		{
			"label": "TaskIQ: worker",
			"type": "shell",
			"command": "uv run python -m api.taskiq worker api.taskiq:broker api.tasks.registry --workers auto --max-async-tasks 25",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"dependsOn": "Docker: ensure dev deps",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Listening started\\."
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "TaskIQ: scheduler",
			"type": "shell",
			"command": "uv run python -m api.taskiq scheduler api.taskiq:scheduler api.tasks.registry",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"dependsOn": "Docker: ensure dev deps",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Startup completed\\."
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "backend: run tests",
			"type": "shell",
			"command": "uv run pytest -q --tb=short --cov-report=term-missing:skip-covered",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"dependsOn": "Docker: ensure dev deps",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},
		{
			"label": "backend: type check",
			"type": "shell",
			"command": "uv run ty check . ../tools/autogen-migration.py ../tools/export-openapi.py",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},
		{
			"label": "backend: check API alive",
			"type": "process",
			"command": "node",
			"args": [
				"-e",
				"const url=process.env.API_HEALTH_URL||'http://localhost:1383/health';const timeoutMs=Number(process.env.API_HEALTH_TIMEOUT_MS||60000);const intervalMs=Number(process.env.API_HEALTH_INTERVAL_MS||1000);const start=Date.now();const urlObj=new URL(url);const http=require(urlObj.protocol==='https:'?'https':'http');async function isOk(){return await new Promise(resolve=>{const req=http.request(urlObj,{method:'GET',headers:{accept:'application/json'}},res=>{res.resume();resolve(Boolean(res.statusCode&&res.statusCode>=200&&res.statusCode<300));});req.on('error',()=>resolve(false));req.end();});}(async()=>{for(;;){if(await isOk()){console.log('API alive: '+url);process.exit(0);}if(Date.now()-start>timeoutMs){console.error('API not reachable after '+timeoutMs+'ms: '+url);process.exit(1);}await new Promise(r=>setTimeout(r,intervalMs));}})();"
			],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},
		{
			"label": "backend: autogen migration",
			"type": "shell",
			"command": "uv run --project backend python tools/autogen-migration.py",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"dependsOn": "Docker: ensure dev deps",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},

		// frontend
		{
			"label": "frontend: install dependencies",
			"type": "shell",
			"command": "pnpm install",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "frontend: dev server",
			"type": "shell",
			"command": "pnpm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "frontend: build",
			"type": "shell",
			"command": "pnpm run build",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "frontend: lint",
			"type": "shell",
			"command": "pnpm run lint",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "frontend: format",
			"type": "shell",
			"command": "pnpm run format",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "frontend: check",
			"type": "shell",
			"command": "pnpm run check",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "frontend: test",
			"type": "shell",
			"command": "pnpm run test",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "frontend: test coverage",
			"type": "shell",
			"command": "pnpm run test:coverage",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},
		{
			"label": "frontend: generate API types",
			"type": "shell",
			"command": "pnpm run generate:api-types",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			}
		},

		// console
		{
			"label": "console: install dependencies",
			"type": "shell",
			"command": "pnpm install",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "console: dev server",
			"type": "shell",
			"command": "pnpm run dev -- --host --port 8383",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "console: build",
			"type": "shell",
			"command": "pnpm run build",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "console: format",
			"type": "shell",
			"command": "pnpm run format",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "console: lint",
			"type": "shell",
			"command": "pnpm run lint",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "console: check",
			"type": "shell",
			"command": "pnpm run check",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "console: test",
			"type": "shell",
			"command": "pnpm run test",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "shared"
			}
		},
		{
			"label": "console: test coverage",
			"type": "shell",
			"command": "pnpm run test:coverage",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "test",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "dedicated"
			}
		},
		{
			"label": "console: generate API types",
			"type": "shell",
			"command": "pnpm run generate:api-types",
			"options": {
				"cwd": "${workspaceFolder}/console"
			},
			"group": "build",
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "shared"
			}
		},

		// Docker
		{
			"label": "Docker: ensure dev deps",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile deps up -d",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"showReuseMessage": false,
				"close": true
			}
		},
		{
			"label": "Docker: build all",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml build",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Docker: build TaskIQ",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile local build taskiq-worker taskiq-scheduler",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": true
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: TaskIQ up",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile local up -d --build taskiq-worker taskiq-scheduler",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": true,
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: stop TaskIQ",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile local rm -sf taskiq-worker taskiq-scheduler",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false,
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: debug API + TaskIQ",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile debug up -d --build backend-debug taskiq-worker-debug taskiq-scheduler-debug",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"dependsOn": "Docker: stop TaskIQ",
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: stop debug API + TaskIQ",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml --profile debug rm -sf backend-debug taskiq-worker-debug taskiq-scheduler-debug",
			"options": {
				"cwd": "${workspaceFolder}/.docker"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"showReuseMessage": false
			},
			"problemMatcher": []
		},

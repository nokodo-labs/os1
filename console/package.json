{
	"name": "nokodo-ai-console",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"generate:api-types": "openapi-typescript http://localhost:1383/v1/openapi.json -o src/lib/api/types.ts",
		"generate:api-client": "openapi --client fetch --useUnionTypes --input http://localhost:1383/v1/openapi.json --output src/lib/api/generated",
		"generate:api": "npm run generate:api-types && npm run generate:api-client"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.556.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.1",
		"@tailwindcss/postcss": "^4.1.16",
		"@tsconfig/svelte": "^5.0.4",
		"@types/node": "^25.0.0",
		"@vitest/coverage-v8": "^4.0.15",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.4.0",
		"happy-dom": "^20.0.11",
		"openapi-typescript": "^7.10.1",
		"openapi-typescript-codegen": "^0.29.0",
		"postcss": "^8.4.47",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.43.1",
		"svelte-check": "^4.0.5",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript-eslint": "^8.49.0",
		"typescript": "^5.6.3",
		"vite": "^7.1.12",
		"vitest": "^4.0.15"
	},
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=10.0.0"
	},
	"dependencies": {
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.4.0",
		"tailwindcss-animate": "^1.0.7"
	}
}
